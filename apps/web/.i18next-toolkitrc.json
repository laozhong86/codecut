{
  "$schema": "./node_modules/@i18next-toolkit/cli/config-schema.json",
  "publicDir": "./public",
  "defaultLocale": "en",
  "locales": [
    "en",
    "zh",
    "ja",
    "ko",
    "es",
    "pt",
    "fr",
    "de",
    "id",
    "vi",
    "ru",
    "it"
  ],
  "namespaces": [
    "translation"
  ],
  "verbose": true,
  "extractor": {
    "input": [
      "./src/**/*.{ts,tsx}",
      "!./src/**/*.spec.{ts,tsx}",
      "!./src/**/*.test.{ts,tsx}",
      "!./src/**/__tests__/**/*.{ts,tsx}",
      "!**/node_modules/**"
    ],
    "output": "./public/locales"
  },
  "scanner": {
    "source": "./src/**/*.tsx",
    "tsconfigPath": "./tsconfig.json",
    "autoImport": false,
    "ignoreFiles": [],
    "ignoreText": [
      "Codecut",
      "CapCut",
      "Better Auth",
      "GitHub",
      "Vercel",
      "X (Twitter)",
      "moonrailgun@gmail.com",
      "English",
      "中文",
      "日本語",
      "한국어",
      "Español",
      "Português",
      "Français",
      "Deutsch",
      "Bahasa Indonesia",
      "Tiếng Việt",
      "Русский",
      "Italiano",
      "DELETE",
      "blob",
      "group-[.toast]:text-muted-foreground",
      "https://api.openai.com/v1",
      "https://example.com/video.mp4",
      "sk-...",
      "gpt-5.2",
      "voice_type",
      "1:1",
      "16:9",
      "9:16",
      "4:3",
      "3:4",
      "21:9",
      "4s",
      "5s",
      "6s",
      "8s",
      "10s",
      "12s",
      "480p",
      "720p",
      "1080p",
      "B",
      "I",
      "U",
      "S",
      "T",
      "x",
      "×",
      "(",
      ")",
      ".",
      "—",
      "— "
    ]
  },
  "translator": {
    "type": "openai",
    "openai": {
      "modelName": "gpt-4o-mini"
    }
  }
}
