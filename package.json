{
  "name": "codecut",
  "packageManager": "bun@1.2.18",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=@codecut/web",
    "build:web": "turbo run build --filter=@codecut/web",
    "lint:web": "biome lint apps/web/src --max-diagnostics=1000",
    "typecheck:web": "bun x tsc -p apps/web/tsconfig.json --noEmit",
    "coverage:focused": "bun test --coverage --coverage-reporter=lcov --coverage-dir=tmp/coverage-focused && node scripts/check-focused-coverage.mjs tmp/coverage-focused/lcov.info",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "lint:web:fix": "biome lint apps/web/src --write --max-diagnostics=1000",
    "format:web": "biome format apps/web/src/services/renderer --write --max-diagnostics=1000",
    "git-hooks:install": "node scripts/git-hooks/install-hooks.mjs",
    "worktree:create": "node scripts/worktree-manager.mjs create",
    "worktree:init": "node scripts/worktree-manager.mjs init",
    "worktree:list": "node scripts/worktree-manager.mjs list",
    "worktree:cleanup": "node scripts/worktree-manager.mjs cleanup",
    "worktree:teardown": "node scripts/worktree-manager.mjs teardown",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "better-auth": "^1.4.15",
    "next": "^16.2.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "^1.58.2",
    "turbo": "^2.7.5",
    "typescript": "5.8.3"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
